{
    "EXCLUDE_PATHS": [
        "STREAMS/",
        "ARCHIVE/",
        "_generated/",
        "node_modules/",
        "build/",
        ".git/",
        ".ai/STATE/",
        "dist/",
        "npm-debug.log"
    ],
    "FORBIDDEN_TRANSFORMS": {
        "command_tokens": [
            "NEW",
            "APPROVE",
            "DELETE",
            "MODIFY"
        ],
        "governance_fields": [
            "loop_id",
            "trust_level",
            "evid_id"
        ],
        "critical_patterns": [
            "0x[0-9a-fA-F]{40}",
            "AG-[0-9]{8}-[0-9]{2}"
        ]
    }
}